{
	"name": "phoxiv",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun run pregen && vite dev",
		"build": "bun run pregen && vite build",
		"preview": "bun run build && wrangler dev",
		"deploy": "bun run build && wrangler deploy",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply DB",
		"db:migrate-remote": "wrangler d1 migrations apply DB --remote",
		"db:studio": "drizzle-kit studio",
		"cf-typegen": "wrangler types ./src/worker-configuration.d.ts",
		"pregen": "bun run ./src/lib/pregen/problems.ts && bun run ./src/lib/pregen/problemNames.ts"
	},
	"devDependencies": {
		"@catppuccin/tailwindcss": "^1.0.0",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@fontsource-variable/figtree": "^5.2.10",
		"@hugeicons/core-free-icons": "^4.0.0",
		"@hugeicons/svelte": "^1.1.2",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"csv-parse": "^6.2.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.5",
		"svelte-seo": "^2.0.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vite": "^8.0.1",
		"wrangler": "^4.76.0"
	},
	"dependencies": {
		"mode-watcher": "^1.1.0"
	}
}
